# AWS Credentials
# At least one authentication method is required.
#
# Method 1: AWS Profile (Recommended for local development)
# AWS_PROFILE=your-profile-name

# Method 2: Explicit Credentials
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Optional: AWS Session Token (for temporary/federated credentials)
# AWS_SESSION_TOKEN=your_session_token_here

# JWT Authentication Secret — used to sign and verify access keys.
# Generate once with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Then generate team access keys with: JWT_SECRET=<secret> npm run generate-key [days]
# JWT_SECRET=your_secret_here

